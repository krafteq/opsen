{
  "name": "@opsen/agent",
  "version": "0.1.1",
  "description": "Pulumi component for deploying the opsen deploy agent to VMs",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "go",
    "go/out",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:go": "cd go && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags='-s -w' -o out/opsen-agent ./cmd/opsen-agent",
    "prepack": "npm run build:go",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@pulumi/command": "^1.0.0",
    "@pulumi/pulumi": "^3.152.0",
    "@pulumi/tls": "^5.0.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  }
}
